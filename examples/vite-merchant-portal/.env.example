# Auth server (@advcomm/uids-io-auth) — examples/express-auth-server
VITE_AUTH_ISSUER=http://localhost:3000
VITE_AUTH_CLIENT_ID=merchant_portal_web
VITE_AUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# Optional: local dev uses different ports (cross-site cookies). Uncomment for body-mode RT:
# VITE_AUTH_TOKEN_DELIVERY=body

# Resource API — use /api in dev (Vite proxies to localhost:4000)
VITE_API_URL=/api
